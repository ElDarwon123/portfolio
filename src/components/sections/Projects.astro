const allTags = [...new Set(projects.flatMap(p => p.tags))];
---

<section id="projects" class="relative py-28 px-6 overflow-hidden">
  <div class="bg-number -left-20 top-10">03</div>

  <div class="max-w-5xl mx-auto relative z-10">
    <Reveal>
      <p class="text-[11px] text-gray-600 font-mono tracking-[4px] uppercase mb-2">// 03</p>
      <h2 class="text-4xl md:text-6xl font-black text-white tracking-[-0.03em]">Proyectos</h2>
    </Reveal>

    <Reveal delay={100}>
      <div class="flex flex-wrap gap-2 mt-8" id="project-filters">
        <button class="filter-btn active skill-tag border-khaos-magenta/50 text-khaos-magenta" data-tag="all">All</button>
        {allTags.map((tag) => (
          <button class="filter-btn skill-tag" data-tag={tag}>{tag}</button>
        ))}
      </div>
    </Reveal>
  </div>

  <div class="mt-14 max-w-4xl mx-auto px-6 space-y-6" id="projects-list">
    {projects.map((proj, i) => (
      <div
        class="project-entry bg-[#111] border border-white/5 overflow-hidden rounded-xl"
        data-tags={proj.tags.join(',')}
        data-index={i}
        style={`border-top: 3px solid ${proj.accent};`}
      >
        <div class="project-image relative overflow-hidden">
          <div class="h-5 bg-[#1a1a1a] border-b border-white/5 flex items-center px-3 gap-1.5">
            <div class="w-2 h-2 rounded-full bg-[#ff5f57]"></div>
            <div class="w-2 h-2 rounded-full bg-[#febc2e]"></div>
            <div class="w-2 h-2 rounded-full bg-[#28c840]"></div>
            <span class="text-[9px] text-gray-600 font-mono ml-2 truncate">{proj.urlDisplay}</span>
          </div>
          <div class={`h-64 bg-gradient-to-br ${proj.gradient} relative overflow-hidden`}>
            {proj.image ? (
              <img src={proj.image} alt={proj.title} class="w-full h-full object-cover" loading="lazy" />
            ) : (
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(255,255,255,0.08)_0%,transparent_50%)]"></div>
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_80%,rgba(255,255,255,0.05)_0%,transparent_40%)]"></div>
            )}
            <div class:list={[
              "project-overlay absolute inset-0 flex items-center justify-center backdrop-blur-[1px] transition-opacity duration-300",
              proj.private ? "bg-black/60 opacity-100" : "bg-black/40 opacity-0 hover:opacity-100"
            ]}>
              <div class="text-center">
                <div class="text-white/90 text-sm font-bold tracking-wider uppercase px-6 py-3 border border-white/20 rounded">
                  Proyecto Privado
                </div>
                <p class="text-white/40 text-[10px] mt-2">No disponible para vista pública</p>
              </div>
            </div>
            <div class="relative h-full flex items-center justify-center">
              <span class="text-white/10 font-mono text-sm text-center px-4 tracking-wider">{proj.title}</span>
            </div>
          </div>
        </div>
        <div class="p-6 space-y-4">
          <div class="flex items-start justify-between gap-2">
            <h3 class="font-bold text-base text-white">{proj.title}</h3>
            <div class="flex items-center gap-2">
              <span class="text-[10px] text-gray-600 font-mono">{proj.year}</span>
              <span class="text-[10px] text-gray-600 bg-white/5 px-2 py-0.5 whitespace-nowrap">{proj.role}</span>
            </div>
          </div>
          <p class="text-sm text-gray-400 leading-relaxed">{proj.description}</p>
          <p class="text-xs text-gray-500 leading-relaxed">{proj.longDescription}</p>
          <div class="flex flex-wrap gap-1.5">
            {proj.tags.map((tag) => (
              <span class="text-[10px] px-2 py-0.5 border border-white/10 text-gray-500">{tag}</span>
            ))}
          </div>
          <div class="flex items-center gap-4">
            {proj.url && (
              <a href={proj.url} target="_blank" rel="noopener noreferrer"
                class="inline-block text-xs font-semibold text-khaos-cyan hover:text-white transition-colors duration-300">
                Visitar proyecto →
              </a>
            )}
            <button class="expand-btn text-xs font-semibold text-gray-500 hover:text-white transition-colors duration-300 cursor-pointer flex items-center gap-1" data-index={i}>
              <span class="expand-text">Ver más detalles</span>
              <span class="expand-icon transition-transform duration-300">↓</span>
            </button>
          </div>
          <div class="expand-content overflow-hidden transition-all duration-500 ease-in-out" style="max-height: 0;" data-index={i}>
            <div class="pt-4 border-t border-white/5 space-y-2">
              <p class="text-[11px] text-gray-500 font-mono uppercase tracking-wider mb-2">Highlights del proyecto</p>
              {proj.highlights.map((h) => (
                <div class="flex items-start gap-2 text-xs text-gray-400">
                  <span class="text-khaos-green mt-1 font-mono text-[10px] shrink-0">▸</span>
                  <span>{h}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>

  <script is:inline>
  (function() {
    document.addEventListener('DOMContentLoaded', function() {
      var filterBtns = document.querySelectorAll('.filter-btn');
      var entries = document.querySelectorAll('.project-entry');
      var expandBtns = document.querySelectorAll('.expand-btn');

      // Filters
      filterBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          filterBtns.forEach(function(b) {
            b.classList.remove('active', 'border-khaos-magenta/50', 'text-khaos-magenta');
          });
          btn.classList.add('active', 'border-khaos-magenta/50', 'text-khaos-magenta');
          var tag = btn.getAttribute('data-tag');
          entries.forEach(function(entry) {
            var entryTags = entry.getAttribute('data-tags');
            if (tag === 'all' || entryTags.includes(tag)) {
              entry.style.display = '';
              entry.style.opacity = '1';
              entry.style.transform = '';
            } else {
              entry.style.opacity = '0';
              entry.style.transform = 'translateY(20px)';
              setTimeout(function() { entry.style.display = 'none'; }, 300);
            }
          });
        });
      });

      // Expand/collapse
      expandBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var idx = btn.getAttribute('data-index');
          var content = document.querySelector('.expand-content[data-index="' + idx + '"]');
          var text = btn.querySelector('.expand-text');
          var icon = btn.querySelector('.expand-icon');
          if (content.style.maxHeight && content.style.maxHeight !== '0px') {
            content.style.maxHeight = '0px';
            text.textContent = 'Ver más detalles';
            icon.style.transform = 'rotate(0deg)';
          } else {
            content.style.maxHeight = content.scrollHeight + 'px';
            text.textContent = 'Ver menos';
            icon.style.transform = 'rotate(180deg)';
          }
        });
      });

      // Scroll animation
      var observer = new IntersectionObserver(function(obsEntries) {
        obsEntries.forEach(function(entry) {
          if (entry.isIntersecting) {
            var el = entry.target;
            var idx = parseInt(el.getAttribute('data-index'));
            var dir = idx % 2 === 0 ? -1 : 1;
            el.style.transition = 'opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.6s cubic-bezier(0.16, 1, 0.3, 1)';
            el.style.opacity = '1';
            el.style.transform = 'translateX(0) rotate(0deg)';
          } else {
            var el = entry.target;
            var idx = parseInt(el.getAttribute('data-index'));
            var dir = idx % 2 === 0 ? -1 : 1;
            if (entry.boundingClientRect.top > 0) {
              el.style.opacity = '0';
              el.style.transform = 'translateX(' + (dir * 120) + 'px) rotate(' + (dir * 2) + 'deg)';
            }
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -100px 0px' });

      entries.forEach(function(entry, i) {
        var dir = i % 2 === 0 ? -1 : 1;
        entry.style.opacity = '0';
        entry.style.transform = 'translateX(' + (dir * 120) + 'px) rotate(' + (dir * 2) + 'deg)';
        observer.observe(entry);
      });
    });
  })();
  </script>
</section>
