    ],
    tags: ['Next.js', 'NestJS', 'GraphQL', 'Arquitectura'],
    gradient: 'from-[#e89600] via-[#cc7a00] to-[#d6007a]',
    image: '/images/projects/ecommerPlatform.png',
    urlDisplay: 'ecommer.shop',
