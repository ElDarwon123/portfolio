---
import Reveal from '../ui/Reveal.astro';

const experience = [
  {
    company: 'Ecommer',
    role: 'Desarrollador Fullstack y Arquitecto de Software',
    location: 'Popayán, Colombia',
    period: 'Sep 2025 — Presente',
    highlights: [
      'Frontend con Next.js y React — interfaces responsivas',
      'Backend con NestJS y GraphQL — APIs escalables',
      'Administración y optimización de bases de datos',
      'Optimización de procesos y peticiones a BD',
      'Definición de arquitecturas y toma de decisiones técnicas',
      'Deploy y mantenimiento de producción',
      'Side project en desarrollo activo',
      'Trabajo en equipo ágil con Scrum',
    ],
  },
  {
    company: 'Premisal Coffee Roaster',
    role: 'Frontend Developer',
    location: 'Remoto',
    period: '2025',
    highlights: [
      'Desarrollo Frontend de plataforma B2B para tueste de café',
      'Interfaces modernas, responsivas y optimizadas con Next.js',
      'Implementación de diseño UI/UX para experiencia de usuario',
    ],
  },
  {
    company: 'BpoLabs',
    role: 'Desarrollador Backend',
    location: 'Popayán, Colombia',
    period: 'Nov 2024 — May 2025',
    highlights: [
      'Rediseño y refactorización — mejora 15-30% en respuestas',
      'Suite de pruebas unitarias con xUnit — >80% cobertura',
      'Integración de SonarQube para análisis estático',
      'Migración a arquitectura de Monolito Modular',
    ],
  },
  {
    company: 'Project Wizzard',
    role: 'Desarrollador Backend Lider',
    location: 'Popayán, Colombia',
    period: 'Jun 2024 — Oct 2024',
    highlights: [
      'Liderazgo del equipo backend',
      'Toma de decisiones técnicas con el cliente',
      'Pruebas de caja blanca',
      'Desarrollo con Monolito Modular',
    ],
  },
];
---

<section id="experience" class="relative py-28 px-6 overflow-hidden">
  <div class="bg-number -right-10 top-10">04</div>

  <div class="max-w-5xl mx-auto relative z-10">
    <Reveal>
      <p class="text-[11px] text-gray-600 font-mono tracking-[4px] uppercase mb-2">// 04</p>
      <h2 class="text-4xl md:text-6xl font-black text-white tracking-[-0.03em]">Experiencia</h2>
    </Reveal>

    <div class="mt-14">
      {experience.map((exp, i) => (
        <Reveal delay={i * 150}>
          <div class="relative pl-10 pb-10 last:pb-0">
            <div class="absolute left-0 top-1 w-5 h-5 rounded-full bg-[#0a0a0a] border-2 border-khaos-magenta shadow-[0_0_15px_rgba(214,0,122,0.3)] flex items-center justify-center z-10">
              <div class="w-2 h-2 rounded-full bg-khaos-magenta"></div>
            </div>
            {i < experience.length - 1 && (
              <div class="absolute left-[9px] top-6 bottom-0 w-px bg-gradient-to-b from-khaos-magenta/40 to-transparent"></div>
            )}
            <div class="bg-[#111] border border-white/5 p-5 hover:border-khaos-magenta/15 transition-colors duration-500">
              <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1 mb-2">
                <h3 class="text-lg font-bold text-white">{exp.company}</h3>
                <span class="text-[11px] text-gray-600 font-mono">{exp.period}</span>
              </div>
              <p class="text-xs text-gray-500 mb-3">
                <span class="text-gray-400 font-semibold">{exp.role}</span>
                <span class="mx-2">•</span>
                <span>{exp.location}</span>
              </p>
              <ul class="space-y-1.5">
                {exp.highlights.map((h) => (
                  <li class="flex items-start gap-2 text-xs text-gray-500">
                    <span class="text-khaos-green mt-1 font-mono text-[10px] shrink-0">▸</span>
                    <span>{h}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </Reveal>
      ))}
    </div>
  </div>
</section>
