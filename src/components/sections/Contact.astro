---
import Reveal from '../ui/Reveal.astro';
---

<section id="contact" class="relative py-28 px-6 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0a] via-[#1a0a12] to-[#0a0a0a]"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-khaos-magenta/40 to-transparent"></div>
  <div class="absolute top-20 left-[10%] w-96 h-96 bg-khaos-magenta/15 rounded-full blur-[150px]"></div>
  <div class="absolute bottom-20 right-[10%] w-80 h-80 bg-khaos-cyan/10 rounded-full blur-[120px]"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-khaos-magenta/5 rounded-full blur-[200px]"></div>

  <div class="max-w-3xl mx-auto relative z-10">
    <Reveal>
      <p class="text-[11px] text-gray-400 font-mono tracking-[4px] uppercase mb-2">// 07</p>
      <h2 class="text-4xl md:text-6xl font-black text-white tracking-[-0.03em]">Contacto</h2>
      <p class="text-sm text-gray-500 mt-3 max-w-md">Cuéntame qué necesitas y juntos encontramos la mejor solución.</p>
    </Reveal>

    <Reveal delay={150}>
      <div class="bg-[#0a0a0a]/60 backdrop-blur-sm border border-white/10 p-6 md:p-8 mt-10">
        <div class="space-y-5">
          <div class="grid sm:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label class="text-xs font-semibold text-gray-500 block">Nombre</label>
              <input type="text" placeholder="Tu nombre" class="w-full px-3 py-2.5 text-sm bg-white/5 border border-white/10 text-white placeholder-gray-600 focus:outline-none focus:border-khaos-magenta transition-colors" />
            </div>
            <div class="space-y-1.5">
              <label class="text-xs font-semibold text-gray-500 block">Email</label>
              <input type="email" placeholder="tu@email.com" class="w-full px-3 py-2.5 text-sm bg-white/5 border border-white/10 text-white placeholder-gray-600 focus:outline-none focus:border-khaos-magenta transition-colors" />
            </div>
          </div>
          <div class="space-y-1.5">
            <label class="text-xs font-semibold text-gray-500 block">Mensaje</label>
            <textarea rows="4" placeholder="Escribe tu mensaje..." class="w-full px-3 py-2.5 text-sm bg-white/5 border border-white/10 text-white placeholder-gray-600 focus:outline-none focus:border-khaos-magenta transition-colors resize-none"></textarea>
          </div>
          <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 pt-2">
            <button class="magnetic px-6 py-3 bg-khaos-magenta text-white text-xs font-bold tracking-wider uppercase hover:shadow-[0_0_30px_rgba(214,0,122,0.5)] transition-all duration-300 cursor-pointer">
              Enviar Mensaje
            </button>
            <div class="flex flex-wrap items-center gap-4 text-xs text-gray-500">
              <a href="https://linkedin.com/in/steven-gomez-dev" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">LinkedIn</a>
              <a href="mailto:darwing.j10@gmail.com" class="hover:text-white transition-colors">Email</a>
              <span>+57 (313) 483-8350</span>
            </div>
          </div>
        </div>
      </div>
    </Reveal>
  </div>
</section>
