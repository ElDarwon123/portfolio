---
export interface Props {
  text: string;
  color?: 'default' | 'magenta' | 'cyan' | 'green' | 'amber';
}

const { text, color = 'default' } = Astro.props;

const colorMap: Record<string, string> = {
  default: 'border-gray-700 text-gray-400 hover:border-gray-500 hover:text-gray-200',
  magenta: 'border-khaos-magenta/30 text-khaos-magenta hover:border-khaos-magenta hover:text-white',
  cyan: 'border-khaos-cyan/30 text-khaos-cyan hover:border-khaos-cyan hover:text-white',
  green: 'border-khaos-green/30 text-khaos-green hover:border-khaos-green hover:text-white',
  amber: 'border-khaos-amber/30 text-khaos-amber hover:border-khaos-amber hover:text-white',
};
---

<span class="skill-tag {colorMap[color]}">
  {text}
</span>
